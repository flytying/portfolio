---
interface Experience {
  company: string;
  role: string;
  period: string;
  description?: string;
  highlights: string[];
}

interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<div class="space-y-0">
  {experiences.map((exp, i) => (
    <div class="reveal grid grid-cols-1 md:grid-cols-[200px_1fr] gap-4 md:gap-12 py-8 border-b border-gray-200">
      <div class="text-sm text-gray-400 font-medium md:pt-1">
        {exp.period}
      </div>
      <div>
        <h3 class="font-heading font-bold text-lg text-black">{exp.role}</h3>
        <p class="text-gray-500 text-sm mt-1">{exp.company}</p>
        {exp.description && <p class="text-gray-600 mt-3 text-sm leading-relaxed">{exp.description}</p>}
        {exp.highlights.length > 0 && (
          <ul class="mt-3 space-y-1.5">
            {exp.highlights.map((h) => (
              <li class="text-sm text-gray-600 flex items-start gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-1.5 flex-shrink-0" />
                {h}
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  ))}
</div>
